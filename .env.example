# umami-report-cloud-runner — environment configuration
# Copy to `.env` and fill in. `.env` is gitignored.

# ============================================================================
# Resend / SMTP  (required)
# ============================================================================
# Resend exposes a standard SMTP gateway. The upstream tool sends over SMTP,
# so pointing it at Resend needs no code changes.
#   host=smtp.resend.com  port=587  user=resend  pass=<your API key>
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx   # used as the SMTP password
EMAIL_FROM=Umami Reports <reports@yourdomain.com>

# Override only if NOT using Resend (defaults shown):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USERNAME=resend
# SMTP_PASSWORD=                 # alternative to RESEND_API_KEY
# SMTP_TLS=true                  # STARTTLS (true for port 587)
# SMTP_SKIP_VERIFY=false         # true to allow self-signed certs
# SMTP_TIMEOUT=30                # seconds

# ============================================================================
# Umami site  (required — single-site form)
# ============================================================================
# Umami has no API keys: it authenticates with the username/password you log
# in with. The website ID (UUID) is under the site's settings in Umami.
UMAMI_BASE_URL=https://analytics.example.com
UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
UMAMI_USERNAME=your-umami-user
UMAMI_PASSWORD=your-umami-pass
SITE_NAME=My Site
REPORT_RECIPIENTS=you@example.com,team@example.com   # comma-separated
TIMEZONE=UTC

# ============================================================================
# Report / app behavior
# ============================================================================
REPORT_TYPE=daily            # daily | weekly  (should match CRON_SCHEDULE cadence)
DRY_RUN=false                # true = generate the report but DON'T send email
DEBUG=false                  # true = app debug logging + print rendered config (pw masked)
MAX_CONCURRENT_JOBS=4
RUST_LOG=info                # trace|debug|info|warn|error (tracing env-filter)

# ============================================================================
# Scheduling
# ============================================================================
CRON_SCHEDULE=0 8 * * *      # supercronic crontab expression (UTC unless TIMEZONE set)
RUN_MODE=cron                # cron = stay up & schedule | once = run a single report and exit
RUN_ON_START=false           # true = fire one report immediately on container start

# ============================================================================
# Multiple sites (optional)
# If SITE_1_BASE_URL is set, the numbered SITE_N_* blocks are used INSTEAD of
# the single-site UMAMI_* block above. Increment N for each additional site.
# ============================================================================
# SITE_1_BASE_URL=https://analytics.example.com
# SITE_1_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# SITE_1_USERNAME=user1
# SITE_1_PASSWORD=pass1
# SITE_1_NAME=Site One
# SITE_1_RECIPIENTS=a@example.com,b@example.com
# SITE_1_TIMEZONE=UTC
#
# SITE_2_BASE_URL=https://umami.other.com
# SITE_2_WEBSITE_ID=...
# SITE_2_USERNAME=user2
# SITE_2_PASSWORD=pass2
# SITE_2_NAME=Site Two
# SITE_2_RECIPIENTS=c@example.com
# SITE_2_TIMEZONE=Asia/Kolkata
